# OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Calendar
GOOGLE_CALENDAR_ID=tu-calendar-id@group.calendar.google.com

# En LOCAL: ruta al JSON
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

# En CLOUD (EasyPanel/Railway/Vercel): contenido completo del JSON inline
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# Alternativa OAuth2 (si no usas service account, descomenta y rellena)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
